import os
import random
import re
from difflib import get_close_matches
from PIL import Image, ImageDraw, ImageFont
import textwrap
import requests
from IPython.display import display

# ── CONFIG ───────────────────────────────────────────────────────────────
MEME_BASES_DIR = "/content/meme_bases"
FONT_DIR       = "/content/fonts"
FONT_PATH      = os.path.join(FONT_DIR, "impact.ttf")  # rename to impact.ttf if needed
OUTPUT_FILE    = "/content/generated_meme.jpg"

FONT_SIZE_TOP    = 72
FONT_SIZE_BOTTOM = 60
STROKE_WIDTH     = 5
STROKE_FILL      = "black"
TEXT_FILL        = "white"

# Vitalik / Ethereum / crypto -flavored sample captions
SAMPLE_CAPTIONS = [
    ("STATE GROWTH", "still trends up... but maybe we just need more redundancy?"),
    ("L2 TRADEOFFS", "zk-rollups compress data, optimistic ones compress trust — pick your poison"),
    ("MEV MITIGATION", "PBS helps, but the searcher still wins if you're not watching closely"),
